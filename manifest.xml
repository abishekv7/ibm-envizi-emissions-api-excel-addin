                    <bt:Image size="32" resid="Units.Icon.32x32" />
                    <bt:Image size="80" resid="Units.Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>actionInsertUnits</FunctionName>
                  </Action>
                </Control>
              </Group>
              <Label resid="EnviziTab.Label" />
            </CustomTab>
          </ExtensionPoint>
          <!-- Context Menu for IBM Envizi Suggestions -->
          <ExtensionPoint xsi:type="ContextMenu">
            <OfficeMenu id="ContextMenuCell">
              <Control xsi:type="Button" id="ActivityRecommendation">
                <Label resid="ActivityRecommendation.Label" />
                <Supertip>
                  <Title resid="ActivityRecommendation.Label" />
                  <Description resid="ActivityRecommendation.Tooltip" />
                </Supertip>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
