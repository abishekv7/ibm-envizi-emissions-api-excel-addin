                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Action xsi:type="ExecuteFunction">
                  <FunctionName>actionShowActivityRecommendation</FunctionName>
                </Action>
              </Control>
            </OfficeMenu>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
