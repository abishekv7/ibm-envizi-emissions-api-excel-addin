  <Version>1.2.0</Version>
  <ProviderName>IBM</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="IBM Envizi Emissions Calculations" />
  <Description DefaultValue="Seamlessly integrate emissions data into your workflows." />
  <IconUrl DefaultValue="https://localhost:8000/assets/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:8000/assets/icon-64.png" />
