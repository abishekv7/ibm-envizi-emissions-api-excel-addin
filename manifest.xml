                    <bt:Image size="32" resid="ActivityTypes.Icon.32x32" />
                    <bt:Image size="80" resid="ActivityTypes.Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>actionInsertActivityType_All</FunctionName>
